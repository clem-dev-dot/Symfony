{% extends 'base.html.twig' %}

{% block title %}Hello BoutiqueController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <a class="contact_btnabck" href="/" >
        <i class="fas fa-2x fa-arrow-circle-left">
        </i>
    </a>
    <h1>Boutique {{ categories|length }} rayon(s) proposé(s)</h1>

    {% for category in categories %}
        <div class="card">
            <img src="{{ asset(category.visuel) }}" alt="{{ category.libelle }}">
            <h3>{{ category.libelle }}</h3>
            <p>{{ category.texte }}</p>
            <a href="{{ path('app_boutique_rayon', {'idCategorie': category.id}) }}">Voir le rayon</a>
        </div>
    {% endfor %}


</div>
{% endblock %}
