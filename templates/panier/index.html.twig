{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block body %}

<h2>Mon Panier</h2>

{% if contenu is empty %}
    <p>Votre panier est vide.</p>
{% else %}
    <table class="table">
        <thead>
            <tr>
                <th>Produit</th>
                <th>Prix unitaire</th>
                <th>Quantité</th>
                <th>Sous-total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for element in contenu %}
            <tr>
                <td>{{ element.produit.libelle }}</td>
                <td>{{ element.produit.prix }} €</td>
                <td>{{ element.quantite }}</td>
                <td>{{ element.produit.prix * element.quantite }} €</td>
                <td>
                    <a href="{{ path('app_panier_ajouter', {'_locale': app.request.attributes.get('_locale'), 'idProduit': element.produit.id, 'quantite': 1}) }}" class="btn btn-sm btn-success">+</a>
                    <a href="{{ path('app_panier_enlever', {'_locale': app.request.attributes.get('_locale'), 'idProduit': element.produit.id, 'quantite': 1}) }}" class="btn btn-sm btn-warning">-</a>
                    <a href="{{ path('app_panier_supprimer', {'_locale': app.request.attributes.get('_locale'), 'idProduit': element.produit.id}) }}" class="btn btn-sm btn-danger">🗑</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <p><strong>Total : {{ total }} €</strong></p>
    <a href="{{ path('app_panier_vider', {'_locale': app.request.attributes.get('_locale')}) }}" class="btn btn-danger">Vider le panier</a>

{% endif %}

{% endblock %}